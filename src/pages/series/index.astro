---
import PageLayout from "@layouts/PageLayout.astro";
import { getAllSeries } from "@lib/content/series";
import { seriesUrl, postUrl } from "@lib/urls";

const allSeries = await getAllSeries();
---

<PageLayout meta={{ title: "系列文章" }}>
  <h1 class="series-title">系列文章</h1>

  {
    allSeries.length > 0 ? (
      <div class="series-list">
        {allSeries.map((s) => (
          <section class="series-section">
            <h2 class="series-name">
              <a href={seriesUrl(s.name)}>{s.name}</a>
              <span class="series-total">{s.count} 篇</span>
            </h2>
            <ol class="series-posts">
              {s.posts.map((p, idx) => (
                <li class="series-post-item">
                  <span class="series-order">
                    {(p.data.seriesOrder ?? idx + 1).toString().padStart(2, "0")}
                  </span>
                  <a href={postUrl(p.id)} class="series-post-link">
                    {p.data.title}
                  </a>
                </li>
              ))}
            </ol>
          </section>
        ))}
      </div>
    ) : (
      <p class="empty">暂无系列文章</p>
    )
  }
</PageLayout>

<style>
  .series-title {
    font-size: var(--font-size-3xl);
    margin-bottom: var(--space-8);
  }

  .series-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-10);
  }

  .series-section {
    padding: var(--space-6);
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border-light);
  }

  .series-name {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    font-size: var(--font-size-xl);
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-border-light);
  }

  .series-name a {
    color: var(--color-text);
  }

  .series-name a:hover {
    color: var(--color-accent);
  }

  .series-total {
    font-size: var(--font-size-sm);
    font-weight: 400;
    color: var(--color-text-muted);
  }

  .series-posts {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .series-post-item {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
  }

  .series-order {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    min-width: 1.5em;
  }

  .series-post-link {
    font-size: var(--font-size-base);
    color: var(--color-link);
  }

  .series-post-link:hover {
    color: var(--color-accent-hover);
  }

  .empty {
    text-align: center;
    color: var(--color-text-muted);
    padding: var(--space-12);
  }
</style>
