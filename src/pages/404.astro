---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout meta={{ title: "页面未找到", description: "404 页面未找到", noindex: true }}>
  <div class="not-found container">
    <h1 class="nf-code">404</h1>
    <p class="nf-message">页面未找到</p>
    <p class="nf-hint">你要找的页面可能已被移动、删除或从未存在。</p>
    <div class="nf-links">
      <a href="/" class="nf-link">返回首页</a>
      <a href="/posts/" class="nf-link">查看文章</a>
      <a href="/search/" class="nf-link">搜索</a>
    </div>
  </div>
</BaseLayout>

<style>
  .not-found {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    text-align: center;
    padding-top: var(--space-16);
    padding-bottom: var(--space-16);
  }

  .nf-code {
    font-size: 6rem;
    font-weight: 800;
    color: var(--color-accent);
    line-height: 1;
    margin-bottom: var(--space-4);
  }

  .nf-message {
    font-size: var(--font-size-xl);
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-3);
  }

  .nf-hint {
    font-size: var(--font-size-base);
    color: var(--color-text-muted);
    margin-bottom: var(--space-8);
    max-width: 400px;
  }

  .nf-links {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
    justify-content: center;
  }

  .nf-link {
    display: inline-flex;
    align-items: center;
    padding: var(--space-2) var(--space-5);
    border-radius: var(--radius-md);
    background: var(--color-surface);
    color: var(--color-text-secondary);
    font-size: var(--font-size-sm);
    border: 1px solid var(--color-border-light);
    transition:
      background var(--transition-fast),
      color var(--transition-fast);
  }

  .nf-link:hover {
    background: var(--color-surface-raised);
    color: var(--color-text);
  }
</style>
