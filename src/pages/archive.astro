---
import PageLayout from "@layouts/PageLayout.astro";
import { getArchive } from "@lib/content/archive";
import { postUrl } from "@lib/urls";

const archive = await getArchive();
---

<PageLayout meta={{ title: "归档" }}>
  <h1 class="archive-title">归档</h1>

  {
    archive.length > 0 ? (
      <div class="archive">
        {archive.map((year) => (
          <section class="archive-year">
            <h2 class="year-heading">{year.year}</h2>
            {year.months.map((month) => (
              <div class="archive-month">
                <h3 class="month-heading">{month.label}</h3>
                <ul class="month-posts">
                  {month.posts.map((post) => (
                    <li class="month-post">
                      <a href={postUrl(post.id)} class="month-post-link">
                        <time datetime={post.data.pubDate.toISOString()} class="month-post-date">
                          {String(post.data.pubDate.getDate()).padStart(2, "0")}日
                        </time>
                        <span class="month-post-title">{post.data.title}</span>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </section>
        ))}
      </div>
    ) : (
      <p class="empty">暂无文章</p>
    )
  }
</PageLayout>

<style>
  .archive-title {
    font-size: var(--font-size-3xl);
    margin-bottom: var(--space-8);
  }

  .archive-year {
    margin-bottom: var(--space-10);
  }

  .year-heading {
    font-size: var(--font-size-2xl);
    color: var(--color-accent);
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-2);
    border-bottom: 2px solid var(--color-accent);
  }

  .archive-month {
    margin-bottom: var(--space-6);
    margin-left: var(--space-4);
  }

  .month-heading {
    font-size: var(--font-size-base);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-3);
  }

  .month-posts {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .month-post-link {
    display: flex;
    gap: var(--space-4);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-md);
    transition: background var(--transition-fast);
  }

  .month-post-link:hover {
    background: var(--color-surface);
  }

  .month-post-date {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }

  .month-post-title {
    font-size: var(--font-size-base);
    color: var(--color-text);
  }

  .empty {
    text-align: center;
    color: var(--color-text-muted);
    padding: var(--space-12);
  }
</style>
