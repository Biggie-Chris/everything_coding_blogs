---
import BaseLayout from "./BaseLayout.astro";
import PostMeta from "@components/post/PostMeta.astro";
import PostTags from "@components/post/PostTags.astro";
import PostSeries from "@components/post/PostSeries.astro";
import TableOfContents from "@components/post/TableOfContents.astro";
import ReadingProgress from "@components/post/ReadingProgress.astro";
import PrevNextNavigation from "@components/post/PrevNextNavigation.astro";
import RelatedPosts from "@components/post/RelatedPosts.astro";
import type { Post } from "@lib/content/posts";
import { getSeriesByName, getSeriesPosition } from "@lib/content/series";
import { estimateReadingTime } from "@lib/dates";

export interface Props {
  post: Post;
  prev: Post | null;
  next: Post | null;
  headings: Array<{ depth: number; slug: string; text: string }>;
}

const { post, prev, next, headings } = Astro.props;

const { Content } = await post.render();
const readingTime = estimateReadingTime(post.body ?? "");
const series = post.data.series ? await getSeriesByName(post.data.series) : undefined;
const position = series ? getSeriesPosition(series, post.id) : undefined;

const tocHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

<BaseLayout
  meta={{
    title: post.data.title,
    description: post.data.description,
    canonical: post.data.canonicalUrl,
    type: "article",
    pubDate: post.data.pubDate,
    updatedDate: post.data.updatedDate,
    tags: post.data.tags,
    image: post.data.cover?.src,
    imageAlt: post.data.cover?.alt,
  }}
>
  <article class="post" itemscope itemtype="https://schema.org/BlogPosting">
    <ReadingProgress />

    {
      tocHeadings.length > 0 && (
        <aside class="post-toc-desktop">
          <TableOfContents headings={tocHeadings} />
        </aside>
      )
    }

    <header class="post-header">
      {post.data.draft && <div class="draft-badge">草稿</div>}
      <h1 class="post-title" itemprop="headline">{post.data.title}</h1>

      <PostMeta
        pubDate={post.data.pubDate}
        updatedDate={post.data.updatedDate}
        readingTime={readingTime}
      />

      {post.data.tags.length > 0 && <PostTags tags={post.data.tags} />}

      {
        series && position && (
          <PostSeries series={series} currentSlug={post.id} position={position} />
        )
      }
    </header>

    <div class="post-content prose">
      {
        tocHeadings.length > 0 && (
          <details class="post-toc-mobile">
            <summary>目录</summary>
            <TableOfContents headings={tocHeadings} />
          </details>
        )
      }

      <Content />
    </div>

    <footer class="post-footer">
      {
        series && position && (
          <PostSeries series={series} currentSlug={post.id} position={position} />
        )
      }

      <PrevNextNavigation
        prev={prev}
        next={next}
        seriesPosts={series?.posts ?? null}
        currentSlug={post.id}
      />

      <RelatedPosts post={post} />
    </footer>
  </article>
</BaseLayout>

<style>
  .post {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, var(--prose-width)) minmax(0, 1fr);
    column-gap: 48px;
    padding-top: var(--space-8);
    padding-bottom: var(--space-16);
  }

  .post-header {
    grid-column: 2;
    grid-row: 1;
    margin-bottom: var(--space-8);
  }

  .draft-badge {
    display: inline-block;
    padding: var(--space-1) var(--space-3);
    background: var(--color-draft-bg);
    color: var(--color-warning-border);
    border-radius: var(--radius-sm);
    font-size: var(--font-size-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: var(--space-4);
  }

  .post-title {
    font-size: var(--font-size-4xl);
    margin-bottom: var(--space-4);
  }

  .post-content {
    grid-column: 2;
    grid-row: 2;
    min-width: 0;
  }

  .post-toc-desktop {
    grid-column: 1;
    grid-row: 2;
    justify-self: end;
    width: var(--toc-width);
    position: sticky;
    top: calc(var(--header-height) + var(--space-8));
    align-self: flex-start;
    max-height: calc(100vh - var(--header-height) - var(--space-16));
    overflow-y: auto;
  }

  .post-toc-mobile {
    display: none;
    margin-bottom: var(--space-6);
    padding: var(--space-4);
    background: var(--color-surface);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border-light);
  }

  .post-toc-mobile summary {
    font-weight: 600;
    cursor: pointer;
    font-size: var(--font-size-sm);
  }

  .post-toc-mobile nav {
    margin-top: var(--space-3);
  }

  .post-footer {
    grid-column: 2;
    grid-row: 3;
    margin-top: var(--space-16);
  }

  @media (max-width: 1200px) {
    .post-toc-desktop {
      display: none;
    }

    .post-toc-mobile {
      display: block;
    }
  }

  @media (max-width: 860px) {
    .post {
      grid-template-columns: 1fr;
      padding-left: clamp(16px, 4vw, 32px);
      padding-right: clamp(16px, 4vw, 32px);
    }

    .post-header,
    .post-content,
    .post-footer {
      grid-column: 1;
    }

    .post-title {
      font-size: var(--font-size-3xl);
    }
  }

  @media (max-width: 640px) {
    .post-title {
      font-size: var(--font-size-2xl);
    }
  }
</style>
