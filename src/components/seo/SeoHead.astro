---
import { site } from "@config/site";
import type { SeoMeta } from "@lib/seo/metadata";
import {
  buildPageTitle,
  buildCanonical,
  buildOpenGraph,
  buildTwitterCard,
} from "@lib/seo/metadata";

export interface Props {
  meta: SeoMeta;
}

const { meta } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "") || "";

const pageTitle = buildPageTitle(meta.title);
const canonical = meta.canonical ?? buildCanonical(Astro.url.pathname);
const og = buildOpenGraph(meta);
const twitter = buildTwitterCard(meta);
---

<!-- Primary Meta -->
<title>{pageTitle}</title>
{meta.description && <meta name="description" content={meta.description} />}
<link rel="canonical" href={canonical} />

{meta.noindex && <meta name="robots" content="noindex, follow" />}

<!-- Open Graph -->
<meta property="og:title" content={og.title} />
<meta property="og:description" content={og.description} />
<meta property="og:url" content={og.url} />
<meta property="og:site_name" content={og.siteName} />
<meta property="og:locale" content={og.locale} />
<meta property="og:type" content={og.type} />
<meta property="og:image" content={og.image} />
<meta property="og:image:alt" content={og.imageAlt} />

{og.pubDate && <meta property="article:published_time" content={og.pubDate} />}
{og.updatedDate && <meta property="article:modified_time" content={og.updatedDate} />}
{og.tags?.map((tag) => <meta property="article:tag" content={tag} />)}

<!-- Twitter Card -->
<meta name="twitter:card" content={twitter.card} />
<meta name="twitter:title" content={twitter.title} />
<meta name="twitter:description" content={twitter.description} />
<meta name="twitter:image" content={twitter.image} />
<meta name="twitter:image:alt" content={twitter.imageAlt} />

<!-- RSS -->
<link rel="alternate" type="application/rss+xml" title={site.title} href={`${base}/rss.xml`} />

<!-- Theme (prevent flash) -->
<script is:inline>
  (function () {
    const stored = localStorage.getItem("theme");
    if (stored === "dark" || stored === "light") {
      document.documentElement.setAttribute("data-theme", stored);
    }
  })();
</script>
