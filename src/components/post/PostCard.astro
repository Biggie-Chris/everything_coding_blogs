---
import type { Post } from "@lib/content/posts";
import { postUrl } from "@lib/urls";
import { formatDate, estimateReadingTime } from "@lib/dates";

export interface Props {
  post: Post;
}

const { post } = Astro.props;
const readingTime = estimateReadingTime(post.body ?? "");
---

<article class="post-card">
  {post.data.featured && <span class="featured-badge">精选</span>}
  {post.data.draft && <span class="draft-badge">草稿</span>}

  {
    post.data.cover && (
      <img
        src={post.data.cover.src}
        alt={post.data.cover.alt}
        class="post-card-image"
        loading="lazy"
      />
    )
  }

  <div class="post-card-body">
    <h2 class="post-card-title">
      <a href={postUrl(post.id)}>{post.data.title}</a>
    </h2>

    <p class="post-card-description">{post.data.description}</p>

    <div class="post-card-meta">
      <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
      <span>{readingTime} 分钟</span>
    </div>

    {
      post.data.tags.length > 0 && (
        <div class="post-card-tags">
          {post.data.tags.slice(0, 3).map((tag) => (
            <span class="post-card-tag">{tag}</span>
          ))}
          {post.data.tags.length > 3 && (
            <span class="post-card-tag-more">+{post.data.tags.length - 3}</span>
          )}
        </div>
      )
    }
  </div>
</article>

<style>
  .post-card {
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition:
      background var(--transition-fast),
      box-shadow var(--transition-fast);
    border: 1px solid var(--color-border-light);
  }

  .post-card:hover {
    background: var(--color-surface-raised);
    box-shadow: var(--shadow-sm);
  }

  .post-card-image {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .post-card-body {
    padding: var(--space-5);
  }

  .featured-badge {
    display: inline-block;
    padding: var(--space-1) var(--space-2);
    background: var(--color-accent);
    color: var(--color-accent-text);
    border-radius: var(--radius-sm);
    font-size: var(--font-size-xs);
    font-weight: 600;
  }

  .draft-badge {
    display: inline-block;
    padding: var(--space-1) var(--space-2);
    background: var(--color-draft-bg);
    color: var(--color-warning-border);
    border-radius: var(--radius-sm);
    font-size: var(--font-size-xs);
    font-weight: 600;
    text-transform: uppercase;
  }

  .post-card-title {
    font-size: var(--font-size-lg);
    margin-top: var(--space-2);
    margin-bottom: var(--space-2);
  }

  .post-card-title a {
    color: var(--color-text);
  }

  .post-card-title a:hover {
    color: var(--color-accent);
  }

  .post-card-description {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    line-height: var(--line-height-relaxed);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-card-meta {
    display: flex;
    gap: var(--space-4);
    margin-top: var(--space-3);
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
  }

  .post-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
    margin-top: var(--space-3);
  }

  .post-card-tag {
    padding: var(--space-0-5) var(--space-2);
    background: var(--color-tag-bg);
    color: var(--color-tag-text);
    border-radius: var(--radius-sm);
    font-size: var(--font-size-xs);
    font-weight: 500;
  }

  .post-card-tag-more {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
  }

  @media (max-width: 640px) {
    .post-card-body {
      padding: var(--space-4);
    }
  }
</style>
