---
export interface Heading {
  depth: number;
  slug: string;
  text: string;
}

export interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
---

<nav class="toc" aria-label="目录">
  <div class="toc-title">目录</div>
  <ul class="toc-list">
    {
      headings.map((h) => (
        <li class:list={["toc-item", `toc-depth-${h.depth}`]}>
          <a href={`#${h.slug}`} class="toc-link">
            {h.text}
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<script>
  const HEADER_OFFSET = 80;

  function getCurrentActiveId(): string | null {
    const headings = document.querySelectorAll("article h2[id], article h3[id], article h4[id]");
    if (headings.length === 0) return null;

    const nearBottom =
      window.innerHeight + window.scrollY >= document.documentElement.scrollHeight - 60;

    if (nearBottom) {
      return headings[headings.length - 1]?.id ?? null;
    }

    let active = headings[0]!;
    for (const h of headings) {
      if (h.getBoundingClientRect().top <= HEADER_OFFSET) {
        active = h;
      } else {
        break;
      }
    }
    return active.id;
  }

  function updateActiveLinks(activeId: string): void {
    const links = document.querySelectorAll(".toc-link");
    links.forEach((link) => {
      const href = link.getAttribute("href");
      const targetId = href ? href.slice(1) : "";
      link.classList.toggle("toc-active", targetId === activeId);
    });
  }

  let ticking = false;

  function handleScroll(): void {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(() => {
      const activeId = getCurrentActiveId();
      if (activeId) updateActiveLinks(activeId);
      ticking = false;
    });
  }

  function handleTocClick(e: MouseEvent): void {
    const link = (e.target as Element).closest(".toc-link");
    if (!link) return;
    const href = link.getAttribute("href");
    if (!href) return;
    const activeId = href.slice(1);
    updateActiveLinks(activeId);
  }

  let scrollListener: (() => void) | null = null;
  let resizeListener: (() => void) | null = null;
  let clickListener: ((e: MouseEvent) => void) | null = null;

  function initToc(): void {
    const links = document.querySelectorAll(".toc-link");
    if (links.length === 0) return;

    if (scrollListener) window.removeEventListener("scroll", scrollListener);
    if (resizeListener) window.removeEventListener("resize", resizeListener);
    if (clickListener) document.removeEventListener("click", clickListener);

    const activeId = getCurrentActiveId();
    if (activeId) updateActiveLinks(activeId);

    scrollListener = handleScroll;
    resizeListener = handleScroll;
    clickListener = handleTocClick;

    window.addEventListener("scroll", scrollListener, { passive: true });
    window.addEventListener("resize", resizeListener, { passive: true });
    document.addEventListener("click", clickListener);
  }

  initToc();
  document.addEventListener("astro:page-load", initToc);
</script>

<style>
  .toc {
    font-size: var(--font-size-sm);
  }

  .toc-title {
    font-weight: 600;
    margin-bottom: var(--space-2);
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: var(--font-size-xs);
  }

  .toc-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .toc-item {
    list-style: none;
  }

  .toc-depth-3 {
    padding-left: var(--space-4);
  }

  .toc-link {
    display: block;
    padding: var(--space-1) var(--space-2);
    color: var(--color-text-muted);
    border-radius: var(--radius-sm);
    transition:
      color var(--transition-fast),
      background var(--transition-fast);
    border-left: 2px solid transparent;
    line-height: var(--line-height-normal);
  }

  .toc-link:hover {
    color: var(--color-text);
    background: var(--color-surface);
  }

  .toc-link.toc-active {
    color: var(--color-accent);
    border-left-color: var(--color-accent);
    background: var(--color-note-bg);
  }

  @media (prefers-reduced-motion: reduce) {
    .toc-link {
      transition: none;
    }
  }
</style>
